<Window x:Class="WpfApp1.Views.LoginView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:WpfApp1.ViewModels"
        Title="Connexion - Hero Arena" Height="350" Width="300" WindowStartupLocation="CenterScreen">

    <Window.DataContext>
        <vm:Login />
    </Window.DataContext>

    <Grid Margin="20">
        <StackPanel VerticalAlignment="Center">
            <TextBlock Text="CONNEXION" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,20"/>

            <TextBlock Text="Nom d'utilisateur :" FontWeight="Bold"/>
            <TextBox Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}" Margin="0,5,0,15" Padding="5"/>

            <TextBlock Text="Mot de passe :" FontWeight="Bold"/>
            <TextBox Text="{Binding Password, UpdateSourceTrigger=PropertyChanged}" Margin="0,5,0,20" Padding="5"/>

            <Button Content="Se connecter" 
                    Command="{Binding SubmitLoginCommand}" 
                    Padding="10" Background="#4CAF50" Foreground="White" FontWeight="Bold"/>
        </StackPanel>
    </Grid>
</Window>