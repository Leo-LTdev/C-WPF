<Window x:Class="WpfApp1.Views.SettingsView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:WpfApp1.ViewModels"
        Title="Settings" Height="250" Width="450" WindowStartupLocation="CenterScreen">

	<Window.DataContext>
		<vm:Settings />
	</Window.DataContext>

	<Grid Margin="20">
		<StackPanel>
			<TextBlock Text="Parametres de la Base de Donnees" FontSize="18" FontWeight="Bold" Margin="0,0,0,15"/>

			<TextBlock Text="URL de connexion :" />
			<TextBox Text="{Binding ConnectionString}" IsReadOnly="True" Background="#EEEEEE" Margin="0,5,0,20" Padding="5"/>

			<Button Content="Initialiser les donnees par defaut"
                    Command="{Binding InitDatabaseCommand}"
                    Padding="10" Background="#007ACC" Foreground="White" FontWeight="Bold"/>
		</StackPanel>
	</Grid>
</Window>