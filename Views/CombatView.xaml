<Window x:Class="WpfApp1.Views.CombatView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Arène de Combat" Height="500" Width="700" WindowStartupLocation="CenterOwner">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="150"/>
        </Grid.RowDefinitions>

        <TextBlock Text="FIGHT !" FontSize="30" FontWeight="Bold" Foreground="DarkRed" HorizontalAlignment="Center" Grid.Row="0" Margin="0,0,0,20"/>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="50"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <TextBlock Text="{Binding Player.Name}" FontSize="24" FontWeight="Bold" Foreground="#007ACC" HorizontalAlignment="Center"/>
                <ProgressBar Value="{Binding Player.Health}" Maximum="200" Height="25" Margin="0,10" Foreground="#4CAF50"/>
                <TextBlock Text="{Binding Player.Health, StringFormat='HP: {0}'}" HorizontalAlignment="Center" FontWeight="Bold"/>

                <TextBlock Text="Vos actions :" Margin="0,20,0,5" FontWeight="Bold"/>
                <ItemsControl ItemsSource="{Binding Player.Spells}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Content="{Binding Name}" 
                                    Command="{Binding DataContext.CastSpellCommand, RelativeSource={RelativeSource AncestorType=Window}}" 
                                    CommandParameter="{Binding}" 
                                    Margin="0,5" Padding="10" Background="LightBlue" Cursor="Hand"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>

            <TextBlock Text="VS" Grid.Column="1" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>

            <StackPanel Grid.Column="2">
                <TextBlock Text="{Binding Enemy.Name}" FontSize="24" FontWeight="Bold" Foreground="DarkRed" HorizontalAlignment="Center"/>
                <ProgressBar Value="{Binding Enemy.Health}" Maximum="200" Height="25" Margin="0,10" Foreground="DarkRed"/>
                <TextBlock Text="{Binding Enemy.Health, StringFormat='HP: {0}'}" HorizontalAlignment="Center" FontWeight="Bold"/>
            </StackPanel>
        </Grid>

        <TextBox Grid.Row="2" Text="{Binding CombatLog}" IsReadOnly="True" VerticalScrollBarVisibility="Auto" Background="#222" Foreground="LightGreen" FontFamily="Consolas" Padding="10"/>
    </Grid>
</Window>