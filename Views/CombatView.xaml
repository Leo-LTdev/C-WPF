<Window x:Class="WpfApp1.Views.CombatView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Arene de Combat" Height="550" Width="800" WindowStartupLocation="CenterOwner">

	<Grid Margin="20">
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="*"/>
			<RowDefinition Height="180"/>
		</Grid.RowDefinitions>

		<TextBlock Text="FIGHT !" FontSize="40" FontWeight="Bold" Foreground="DarkRed"
                   HorizontalAlignment="Center" Grid.Row="0" Margin="0,0,0,20">
			<TextBlock.Effect>
				<DropShadowEffect BlurRadius="5" Color="Black" ShadowDepth="2"/>
			</TextBlock.Effect>
		</TextBlock>

		<Grid Grid.Row="1">
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="*"/>
				<ColumnDefinition Width="80"/>
				<ColumnDefinition Width="*"/>
			</Grid.ColumnDefinitions>

			<Border Grid.Column="0" BorderBrush="#007ACC" BorderThickness="2" CornerRadius="10" Padding="15" Background="#F0F8FF">
				<Grid>
					<Grid.RowDefinitions>
						<RowDefinition Height="Auto"/>
						<RowDefinition Height="Auto"/>
						<RowDefinition Height="*"/>
					</Grid.RowDefinitions>

					<StackPanel Grid.Row="0">
						<TextBlock Text="{Binding Player.Name}" FontSize="26" FontWeight="Bold" Foreground="#007ACC" HorizontalAlignment="Center"/>

						<Grid Margin="0,15">
							<ProgressBar Value="{Binding PlayerHealth}" Maximum="{Binding Player.Health}" Height="30" Foreground="#4CAF50" Background="#DDD"/>
							<TextBlock Text="{Binding PlayerHealth, StringFormat='HP: {0}'}" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold"/>
						</Grid>
					</StackPanel>

					<TextBlock Grid.Row="1" Text="ACTIONS :" FontWeight="Bold" Margin="0,10,0,5" FontSize="14"/>

					<ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Padding="0,0,5,0">
						<ItemsControl ItemsSource="{Binding Player.Spells}">
							<ItemsControl.ItemTemplate>
								<DataTemplate>
									<Button Content="{Binding Name}"
                                            Command="{Binding DataContext.CastSpellCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="{Binding}"
                                            Margin="0,4" Padding="12" FontSize="14" FontWeight="SemiBold"
                                            Background="#007ACC" Foreground="White" Cursor="Hand">
										<Button.Resources>
											<Style TargetType="Border">
												<Setter Property="CornerRadius" Value="5"/>
											</Style>
										</Button.Resources>
									</Button>
								</DataTemplate>
							</ItemsControl.ItemTemplate>
						</ItemsControl>
					</ScrollViewer>
				</Grid>
			</Border>

			<TextBlock Text="VS" Grid.Column="1" FontSize="36" FontWeight="Bold"
                       HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="Gray"/>

			<Border Grid.Column="2" BorderBrush="DarkRed" BorderThickness="2" CornerRadius="10" Padding="15" Background="#FFF5F5">
				<StackPanel>
					<TextBlock Text="{Binding Enemy.Name}" FontSize="26" FontWeight="Bold" Foreground="DarkRed" HorizontalAlignment="Center"/>

					<Grid Margin="0,15">
						<ProgressBar Value="{Binding EnemyHealth}" Maximum="{Binding Enemy.Health}" Height="30" Foreground="DarkRed" Background="#DDD"/>
						<TextBlock Text="{Binding EnemyHealth, StringFormat='HP: {0}'}" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold" Foreground="White"/>
					</Grid>

					<Image Source="https://cdn-icons-png.flaticon.com/512/606/606506.png" Height="100" Margin="0,20" Opacity="0.8"/>
				</StackPanel>
			</Border>
		</Grid>

		<GroupBox Header="Journal de combat" Grid.Row="2" Margin="0,20,0,0" FontWeight="Bold">
			<TextBox Text="{Binding CombatLog}" IsReadOnly="True" VerticalScrollBarVisibility="Auto"
                     Background="#1E1E1E" Foreground="#C5E1A5" FontFamily="Consolas" FontSize="14"
                     Padding="10" BorderThickness="0"/>
		</GroupBox>
	</Grid>
</Window>