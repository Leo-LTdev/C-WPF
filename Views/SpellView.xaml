<Window x:Class="WpfApp1.Views.SpellView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:WpfApp1.ViewModels"
        Title="Bibliotheque des Sorts" Height="450" Width="600" WindowStartupLocation="CenterScreen">

    <Window.DataContext>
        <vm:SpellManagement />
    </Window.DataContext>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="Filtrer par héros :" VerticalAlignment="Center" Margin="0,0,10,0" FontWeight="Bold"/>
            <ComboBox ItemsSource="{Binding Heroes}" 
                      SelectedItem="{Binding SelectedHeroFilter}" 
                      DisplayMemberPath="Name" 
                      Width="200" />
            <Button Content="Réinitialiser" Command="{Binding ResetFilterCommand}" Margin="10,0,0,0" Padding="10,2"/>
        </StackPanel>

        <ListBox ItemsSource="{Binding FilteredSpells}" Grid.Row="1" HorizontalContentAlignment="Stretch">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border BorderBrush="LightGray" BorderThickness="0,0,0,1" Padding="10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150"/>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="14" Grid.Column="0"/>
                            <TextBlock Text="{Binding Damage, StringFormat='Dégâts: {0}'}" Foreground="DarkRed" Grid.Column="1"/>
                            <TextBlock Text="{Binding Description}" FontStyle="Italic" Foreground="Gray" Grid.Column="2" TextWrapping="Wrap"/>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </Grid>
</Window>